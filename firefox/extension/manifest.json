{
  "manifest_version": 2,
  "name": "joaogsleite-extension",
  "version": "1.0.10",
  "permissions": [
    "tabs",
    "contextualIdentities",
    "cookies",
    "webRequest",
    "webRequestBlocking",
    "*://*/*",
    "scripting"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": true
  }
}